# wolfir — Environment Variables
# Copy this file to .env and fill in your values

# ========== AWS ==========
# AWS credentials: use aws configure, or set below
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# AWS region for Bedrock and CloudTrail
AWS_REGION=us-east-1

# AWS CLI profile name (default: "default")
AWS_PROFILE=default

# Optional: Cross-account role ARN for CloudTrail/Security Hub
# AWS_TARGET_ROLE_ARN=arn:aws:iam::123456789012:role/WolfirRole

# Optional: CloudTrail regions (comma-separated)
# CLOUDTRAIL_REGIONS=us-east-1,ap-northeast-1

# Optional: X-API-Key auth — set to any secret string to require the header on all /api/* requests.
# Leave blank for local demo (no auth needed). Use when exposing backend publicly.
# WOLFIR_API_KEY=

# Optional: Amazon Bedrock Guardrails — when set, all Nova invocations use this guardrail
# Create a guardrail in Bedrock console, then add its ID here. Restart backend after change.
# Configure loop-prevention: set max output length, deny topics, and content filters to avoid
# runaway agent loops. See Bedrock console > Guardrails > your guardrail.
# GUARDRAIL_IDENTIFIER=your-guardrail-id
# GUARDRAIL_VERSION=1

# Nova 2 Lite extended thinking: low | medium | high (default: medium for agentic workflows)
# NOVA_REASONING_EFFORT=medium

# Optional: Knowledge sources for playbook retrieval (use one or both)
# AWS Knowledge MCP — remote, no Terraform, real-time AWS docs (easiest)
# USE_AWS_KNOWLEDGE_MCP=true
# Bedrock Knowledge Base — deploy terraform/ then create KB in Bedrock console
# KNOWLEDGE_BASE_ID=

# ========== Backend ==========
# CORS: Frontend URL for local dev (e.g. http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Debug mode (set to 1 for dev)
# DEBUG=1

# ========== Frontend — Documentation Tab ==========
# Optional: Open-in-app links for Automated Documentation tab
# See docs/DOCUMENTATION_INTEGRATIONS.md for step-by-step setup
# VITE_JIRA_BASE_URL=https://your-company.atlassian.net
# VITE_SLACK_CHANNEL_URL=https://app.slack.com/client/T.../C...  (your #security-incidents channel)
# VITE_CONFLUENCE_BASE_URL=https://your-company.atlassian.net/wiki
# VITE_CONFLUENCE_SPACE_KEY=SEC  (space key for incident postmortems)

# ========== Optional APIs ==========
# Nova Act (browser automation SDK)
# NOVA_ACT_API_KEY=

# Threat intel (optional)
# ABUSEIPDB_API_KEY=
# VIRUSTOTAL_API_KEY=
